            <input type="range" min="1" max="5" value="3" id="simSpd" oninput="document.getElementById('spdLbl').textContent=this.value+'x'; if(simRunning){clearInterval(simIv);startSimIv();}">
            <span id="spdLbl">3x</span>
          </div>
