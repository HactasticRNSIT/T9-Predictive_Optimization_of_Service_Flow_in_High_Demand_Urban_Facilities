          <span class="sc-icon">📍</span>
          <div class="sc-val" id="u-occ">—</div>
          <div class="sc-lbl">Live Occupancy</div>
        </div>
        <div class="stat-card c-yellow">
          <span class="sc-icon">🤖</span>
          <div class="sc-val" id="u-conf">—</div>
          <div class="sc-lbl">AI Confidence</div>
        </div>
      </div>
      <div class="occ-panel">
        <div class="occ-header">
          <h2>📊 Facility Occupancy (Sensor Data)</h2>
          <div class="occ-big" id="u-occ-big" style="color:var(--neon)">—</div>
        </div>
        <div class="occ-track"><div class="occ-fill" id="u-occ-bar" style="width:0%;background:var(--neon)"></div></div>
        <div class="occ-labels"><span>Empty</span><span id="u-occ-pct">No data yet</span><span>Max (300)</span></div>
        <div style="padding:1rem;background:rgba(0,255,180,0.04);border:1px dashed rgba(0,255,180,0.2);border-radius:10px;font-size:0.85rem;color:var(--text2);text-align:center;margin-top:1rem;">
          💡 Sensor data is populated when the admin runs the hardware simulation. Go to <strong style="color:var(--neon)">Admin → Hardware & IoT</strong> to start the sensor feed.
        </div>
      </div>
    </div>

  </div>
</div>

<script>
/* ======================== DATA ======================== */
const FACILITIES = [
  {id:'hospital',icon:'🏥',label:'Hospitals'},{id:'airport',icon:'✈️',label:'Airports'},
  {id:'bank',icon:'🏦',label:'Banks'},{id:'govt',icon:'🏛️',label:'Govt Offices'},
  {id:'railway',icon:'🚂',label:'Railway Stations'},{id:'rto',icon:'🚗',label:'RTO Offices'},
  {id:'post',icon:'📮',label:'Post Offices'},{id:'police',icon:'🚔',label:'Police Stations'},
  {id:'court',icon:'⚖️',label:'Courts'},{id:'tax',icon:'💼',label:'Tax Offices'},
  {id:'college',icon:'🎓',label:'Colleges/Schools'},{id:'metro',icon:'🚇',label:'Metro Stations'},
];
const LOCATIONS = {
  hospital:['AIIMS Delhi','Safdarjung Hospital','Apollo Hospitals Bannerghatta','Manipal Hospital Whitefield','Fortis Hospital BG Road','Victoria Hospital Bangalore','KEM Hospital Mumbai','PGI Chandigarh'],
  airport:['Kempegowda International Airport','Indira Gandhi Intl Airport','Chhatrapati Shivaji Intl Airport','Rajiv Gandhi Intl Airport','Chennai International Airport'],
  bank:['SBI Main Branch Bangalore','HDFC Bank MG Road','Punjab National Bank Connaught Place','Bank of India Nariman Point','Canara Bank Rajajinagar'],
  govt:['BBMP Headquarters Bangalore','Secretariat North Block Delhi','Mantralaya Mumbai','Telangana Secretariat','Chennai Collectorate'],
  railway:['KSR Bangalore City Station','New Delhi Railway Station','Chhatrapati Shivaji Terminus','Howrah Junction','Chennai Central'],
  rto:['RTO Koramangala','RTO Yeshwanthpur','RTO Marathahalli','RTO Mysore Road','RTO Delhi Saket'],
  post:['GPO Bangalore','GPO New Delhi','GPO Mumbai','GPO Chennai','GPO Kolkata'],
  police:['Cubbon Park Police Station','Koramangala Police Station','CP Police HQ Delhi','Lalbazar Kolkata','Crawford Market PS Mumbai'],
  court:['High Court of Karnataka','Patiala House Courts Delhi','Bombay High Court','Madras High Court','Calcutta High Court'],
  tax:['Income Tax Office Bangalore','Income Tax Office Delhi','Income Tax Office Mumbai','IT Office Chennai','GST Office Bangalore'],
  college:['IISc Bangalore','IIT Delhi','IIT Bombay','NIT Surathkal','Delhi University North Campus'],
  metro:['Majestic Metro Station','Rajajinagar Metro','Whitefield Metro','Kashmere Gate Metro Delhi','Versova Metro Mumbai'],
};

let facilityData = {};
let currentRole = '';
let selFacAdmin = 'hospital';
let selFacUser  = 'hospital';

/* ======================== ROUTING ======================== */
function showPage(id) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}
function goToLogin(role) {
  currentRole = role;
  document.getElementById('login-title').textContent = role==='admin' ? 'Admin Login' : 'Citizen Login';
  document.getElementById('login-sub').textContent   = role==='admin' ? 'Access the facility management dashboard' : 'Check live queue status and facility conditions';
  document.getElementById('login-btn').className     = 'login-btn' + (role==='user' ? ' green' : '');
  document.getElementById('login-user').value = '';
  document.getElementById('login-pass').value = '';
  document.getElementById('login-error').style.display = 'none';
  showPage('login');
}
function doLogin() {
  const u = document.getElementById('login-user').value.trim();
  const p = document.getElementById('login-pass').value.trim();
  const err = document.getElementById('login-error');
  if (currentRole==='admin' && u==='admin' && p==='admin123') {
    showPage('admin-dash'); initAdmin();
  } else if (currentRole==='user' && u==='user' && p==='user123') {
    showPage('user-dash'); initUser();
  } else {
    err.style.display='block';
    setTimeout(()=>err.style.display='none',3000);
  }
}
function logout() { showPage('landing'); }

/* ======================== TABS ======================== */
function switchAdminTab(tab, btn) {
  document.querySelectorAll('#admin-dash .nav-tab').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('#admin-dash .tab-section').forEach(s=>s.classList.remove('active'));
  document.getElementById('admin-tab-'+tab).classList.add('active');
  if (tab==='records') renderAdminTable();
}
function switchUserTab(tab, btn) {
  document.querySelectorAll('#user-dash .nav-tab').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('#user-dash .tab-section').forEach(s=>s.classList.remove('active'));
  document.getElementById('user-tab-'+tab).classList.add('active');
  if (tab==='sensor') updateUserSensorView();
}

/* ======================== CHIPS & SELECTS ======================== */
function buildChips(containerId, role) {
  const container = document.getElementById(containerId);
  const selected  = role==='admin' ? selFacAdmin : selFacUser;
  container.innerHTML = '';
  FACILITIES.forEach(f => {
    const chip = document.createElement('div');
    chip.className = 'fac-chip' + (f.id===selected ? ' active' : '');
    chip.innerHTML = `<span class="fac-icon">${f.icon}</span>${f.label}`;
    chip.onclick = () => {
      if (role==='admin') { selFacAdmin=f.id; initAdmin(); }
      else { selFacUser=f.id; renderUserDash(); }
    };
    container.appendChild(chip);
  });
}
function buildLocationSelect(selectId, facility) {
  const sel = document.getElementById(selectId);
  sel.innerHTML = (LOCATIONS[facility]||[]).map(l=>`<option value="${l}">${l}</option>`).join('');
}

/* ======================== ADMIN ======================== */
function initAdmin() {
  buildChips('facility-chips-admin','admin');
  buildLocationSelect('admin-location', selFacAdmin);
  renderAdminOverview();
  renderAlerts();
  updateClock('admin-time');
}
function renderAdminOverview() {
  const fac = selFacAdmin;
  const loc = document.getElementById('admin-location')?.value||'';
  const d   = (facilityData[fac]&&facilityData[fac][loc])||{};
  const items = [
    {icon:'👥',val:d.queue!==undefined?d.queue:'—',lbl:'Queue Length',cls:'c-purple'},
    {icon:'🚶',val:d.traffic!==undefined?d.traffic:'—',lbl:'Foot Traffic',cls:'c-blue'},
    {icon:'⏱️',val:d.service!==undefined?d.service+'m':'—',lbl:'Service Duration',cls:'c-orange'},
    {icon:'👨‍💼',val:d.staff!==undefined?d.staff+'/10':'—',lbl:'Staff Available',cls:'c-green'},
    {icon:'📊',val:d.capacity!==undefined?d.capacity+'%':'—',lbl:'Capacity',cls:'c-red'},
    {icon:'⏳',val:d.wait!==undefined?d.wait+'m':'—',lbl:'Est. Wait Time',cls:'c-yellow'},
  ];
  document.getElementById('admin-overview').innerHTML = items.map(it=>
    `<div class="stat-card ${it.cls}"><span class="sc-icon">${it.icon}</span><div class="sc-val">${it.val}</div><div class="sc-lbl">${it.lbl}</div></div>`
  ).join('');
}
function submitData() {
  const fac = selFacAdmin;
  const loc = document.getElementById('admin-location').value;
  if (!facilityData[fac]) facilityData[fac]={};
  facilityData[fac][loc] = {
    queue:    parseInt(document.getElementById('f-queue').value)||0,
    traffic:  parseInt(document.getElementById('f-traffic').value)||0,
    staff:    parseInt(document.getElementById('f-staff').value),
    service:  parseInt(document.getElementById('f-service').value),
    capacity: parseInt(document.getElementById('f-capacity').value)||0,
    wait:     parseInt(document.getElementById('f-wait').value)||0,
    category: document.getElementById('f-category').value,
    peak:     document.getElementById('f-peak').value,
    status:   document.getElementById('f-status').value,
    notes:    document.getElementById('f-notes').value,
    timestamp:new Date().toLocaleTimeString(),
  };
  const msg = document.getElementById('success-msg');
  msg.style.display='block';
  setTimeout(()=>msg.style.display='none',3000);
  renderAdminOverview();
  renderAlerts();
}
function statusBadge(s) {
  const map={normal:['badge-green','🟢 Normal'],busy:['badge-orange','🟡 Busy'],critical:['badge-red','🔴 Critical'],closed:['badge-red','⚫ Closed'],maintenance:['badge-orange','🔧 Maintenance']};
  const [cls,label]=map[s]||['badge-blue',s];
  return `<span class="badge ${cls}">${label}</span>`;
}
function renderAdminTable() {
  const container = document.getElementById('admin-table-container');
  const rows=[];
  FACILITIES.forEach(f=>{
    (LOCATIONS[f.id]||[]).forEach(l=>{
      const d=facilityData[f.id]&&facilityData[f.id][l];
      if(d) rows.push({...d,facObj:f,location:l});
    });
  });
  if(!rows.length){
    container.innerHTML=`<div class="empty-state"><div class="es-icon">📡</div><h3>No Data Published Yet</h3><p>Select a facility and publish metrics using the form above.</p></div>`;
    return;
  }
  container.innerHTML=`<table class="data-table">
    <thead><tr><th>Facility</th><th>Location</th><th>Queue</th><th>Traffic</th><th>Service</th><th>Staff</th><th>Capacity</th><th>Wait</th><th>Status</th><th>Category</th><th>Updated</th></tr></thead>
    <tbody>${rows.map(r=>`<tr>
      <td>${r.facObj.icon} ${r.facObj.label}</td><td>${r.location}</td>
      <td><strong>${r.queue}</strong></td><td>${r.traffic}</td><td>${r.service}m</td><td>${r.staff}/10</td>
      <td><div class="flow-bar"><div class="flow-fill" style="width:${r.capacity}%;background:${r.capacity>80?'var(--red)':r.capacity>60?'var(--orange)':'var(--green)'}"></div></div> ${r.capacity}%</td>
      <td>${r.wait}m</td><td>${statusBadge(r.status)}</td>
      <td>${r.category?`<span class="badge badge-blue">${r.category}</span>`:'—'}</td>
      <td style="color:var(--text3);font-family:var(--mono);font-size:0.78rem">${r.timestamp}</td>
    </tr>`).join('')}</tbody></table>`;
  document.getElementById('admin-last-updated').textContent='Last updated: '+new Date().toLocaleString();
}
function renderAlerts() {
  const list=document.getElementById('alert-list');
  const alerts=[];
  FACILITIES.forEach(f=>{
    (LOCATIONS[f.id]||[]).forEach(l=>{
      const d=facilityData[f.id]&&facilityData[f.id][l];
      if(!d) return;
      if(d.capacity>90||d.status==='critical')
        alerts.push({severity:'high',title:`${f.icon} ${l}`,sub:`Capacity at ${d.capacity}% — Overcrowded!`});
      else if(d.capacity>70||d.wait>30)
        alerts.push({severity:'med',title:`${f.icon} ${l}`,sub:`High demand — Wait time ${d.wait}m`});
      else
        alerts.push({severity:'low',title:`${f.icon} ${l}`,sub:'Operating normally'});
    });
  });
  if(!alerts.length) alerts.push({severity:'low',title:'All systems nominal',sub:'No published data yet'});
  list.innerHTML=alerts.slice(0,8).map(a=>
    `<div class="alert-item"><div class="alert-dot ${a.severity}"></div><div class="alert-content"><div class="al-title">${a.title}</div><div class="al-sub">${a.sub}</div></div></div>`
  ).join('');
}

/* ======================== USER ======================== */
function initUser() {
  buildChips('facility-chips-user','user');
  buildLocationSelect('user-location', selFacUser);
  renderUserDash();
  updateClock('user-time');
}
function renderUserDash() {
  buildChips('facility-chips-user','user');
  buildLocationSelect('user-location', selFacUser);
  renderLiveCards();
  renderUserTable();
}
function renderLiveCards() {
  const container = document.getElementById('live-cards');
  const fac=selFacUser;
  const locs=LOCATIONS[fac]||[];
  const facObj=FACILITIES.find(f=>f.id===fac);
  const cards=locs.map(l=>{
    const d=facilityData[fac]&&facilityData[fac][l];
    if(!d) return '';
    const cap=d.capacity||0;
    const circ=2*Math.PI*35;
    const fill=circ-(cap/100)*circ;
    const color=cap>80?'var(--red)':cap>60?'var(--orange)':'var(--green)';
    return `<div class="live-card fade-in">
      <div class="live-card-header">
        <div class="lc-title">${facObj.icon} ${l}</div>
        <div class="live-indicator"><div class="live-dot"></div>Live</div>
      </div>
      <div class="capacity-ring">
        <svg viewBox="0 0 80 80"><circle class="ring-bg" cx="40" cy="40" r="35"/>
        <circle class="ring-fill" cx="40" cy="40" r="35" stroke="${color}" stroke-dasharray="${circ-fill} ${fill}"/></svg>
        <div class="ring-label" style="color:${color}">${cap}%</div>
      </div>
      <div class="metric-row"><span class="m-key">👥 Queue Length</span><span class="m-val">${d.queue} persons</span></div>
      <div class="metric-row"><span class="m-key">⏳ Est. Wait Time</span><span class="m-val" style="color:${d.wait>30?'var(--red)':d.wait>15?'var(--orange)':'var(--green)'}">${d.wait} min</span></div>
      <div class="metric-row"><span class="m-key">🚶 Foot Traffic</span><span class="m-val">${d.traffic}</span></div>
      <div class="metric-row"><span class="m-key">⏱️ Service Time</span><span class="m-val">${d.service} min</span></div>
      <div class="metric-row"><span class="m-key">👨‍💼 Staff On Duty</span><span class="m-val">${d.staff}/10</span></div>
      <div class="metric-row"><span class="m-key">🕐 Peak Hours</span><span class="m-val" style="font-size:0.8rem">${d.peak}</span></div>
      <div class="metric-row"><span class="m-key">Status</span><span>${statusBadge(d.status)}</span></div>
      ${d.notes?`<div style="margin-top:10px;background:rgba(255,255,255,0.04);border-radius:8px;padding:10px;font-size:0.82rem;color:var(--text2)">📢 ${d.notes}</div>`:''}
    </div>`;
  }).join('');
  container.innerHTML=cards||`<div class="empty-state" style="grid-column:1/-1"><div class="es-icon">${facObj?.icon||'🏢'}</div><h3>No Live Data Available</h3><p>Facility administrators haven't published data for this location yet. Check back soon!</p></div>`;
}
function renderUserTable() {
  const container=document.getElementById('user-table-container');
  const rows=[];
  FACILITIES.forEach(f=>{
    (LOCATIONS[f.id]||[]).forEach(l=>{
      const d=facilityData[f.id]&&facilityData[f.id][l];
      if(d) rows.push({...d,facObj:f,location:l});
    });
  });
  if(!rows.length){
    container.innerHTML=`<div class="empty-state"><div class="es-icon">📡</div><h3>No Data Available Yet</h3><p>Admins have not published any facility data. Please check back later.</p></div>`;
    return;
  }
  container.innerHTML=`<table class="data-table">
    <thead><tr><th>Facility</th><th>Location</th><th>Queue</th><th>Wait</th><th>Capacity</th><th>Service</th><th>Staff</th><th>Category</th><th>Status</th><th>Peak Hours</th></tr></thead>
    <tbody>${rows.map(r=>`<tr>
      <td>${r.facObj.icon} ${r.facObj.label}</td><td>${r.location}</td>
      <td><strong>${r.queue}</strong> persons</td>
      <td style="color:${r.wait>30?'var(--red)':r.wait>15?'var(--orange)':'var(--green)'}">${r.wait}m</td>
      <td><div class="flow-bar"><div class="flow-fill" style="width:${r.capacity}%;background:${r.capacity>80?'var(--red)':r.capacity>60?'var(--orange)':'var(--green)'}"></div></div> ${r.capacity}%</td>
      <td>${r.service}m</td><td>${r.staff}/10</td>
      <td>${r.category?`<span class="badge badge-blue">${r.category}</span>`:'—'}</td>
      <td>${statusBadge(r.status)}</td>
      <td style="font-size:0.78rem;color:var(--text2)">${r.peak}</td>
    </tr>`).join('')}</tbody></table>`;
  document.getElementById('user-last-updated').textContent='Data as of: '+new Date().toLocaleString();
}

/* ======================== SENSOR SIMULATION ======================== */
let simRunning=false, simIv=null, entries=0, exits=0, recentArr=[];
const MAX_OCC=300;

function toggleSim(){ simRunning ? stopSim() : startSim(); }
function startSim(){
  simRunning=true;
  document.getElementById('simBtn').textContent='⏹️ Stop Simulation';
  document.getElementById('simBtn').classList.add('stop');
  document.getElementById('sim-status').textContent='LIVE';
  startSimIv();
}
function startSimIv(){
  simIv=setInterval(()=>{
    const occ=entries-exits;
    if(Math.random()>0.42 && occ<MAX_OCC){ entries++; document.getElementById('dA-v').textContent=Math.floor(Math.random()*8)+2; flashNode('dA'); addSimLog('entry'); }
    else if(occ>0){ exits++; document.getElementById('dB-v').textContent=Math.floor(Math.random()*6)+1; flashNode('dB'); addSimLog('exit'); }
    renderSim();
  }, Math.round(2000/+document.getElementById('simSpd').value));
}
function stopSim(){
  simRunning=false; clearInterval(simIv);
  document.getElementById('simBtn').textContent='▶️ Start Simulation';
  document.getElementById('simBtn').classList.remove('stop');
  document.getElementById('sim-status').textContent='PAUSED';
}
function resetSim(){
  stopSim(); entries=0; exits=0; recentArr=[]; renderSim();
  document.getElementById('sim-log').innerHTML='<div class="ll"><span class="lt">--:--:--</span><span style="color:var(--text3)">Reset. Press START to begin.</span></div>';
  document.getElementById('sim-status').textContent='STANDBY';
  ['dA-v','dB-v'].forEach(id=>document.getElementById(id).textContent='0');
}
function renderSim(){
  const occ=Math.max(0,entries-exits);
  const pct=Math.min(100,Math.round(occ/MAX_OCC*100));
  const col=pct<50?'var(--neon)':pct<80?'#f59e0b':'var(--red)';
  // Admin hardware view
  document.getElementById('hub-occ').textContent=occ;
  document.getElementById('occ-big').textContent=occ;
  document.getElementById('occ-big').style.color=col;
  document.getElementById('occ-bar').style.width=pct+'%';
  document.getElementById('occ-bar').style.background=col;
  document.getElementById('occ-pct').textContent=pct+'% capacity';
  document.getElementById('ms-e').textContent=entries;
  document.getElementById('ms-x').textContent=exits;
  document.getElementById('c-entry').textContent=entries;
  document.getElementById('c-exit').textContent=exits;
  document.getElementById('c-occ').textContent=occ;
  const now=Date.now();
  recentArr=recentArr.filter(t=>now-t<60000);
  recentArr.push(now);
  document.getElementById('ms-r').textContent=recentArr.length+'/min';
  const conf=Math.min(98,60+Math.floor(entries/5));
  document.getElementById('c-conf').textContent=conf+'%';
  // User sensor view
  document.getElementById('u-entry').textContent=entries;
  document.getElementById('u-exit').textContent=exits;
  document.getElementById('u-occ').textContent=occ;
  document.getElementById('u-conf').textContent=conf+'%';
  document.getElementById('u-occ-big').textContent=occ;
  document.getElementById('u-occ-big').style.color=col;
  document.getElementById('u-occ-bar').style.width=pct+'%';
  document.getElementById('u-occ-bar').style.background=col;
  document.getElementById('u-occ-pct').textContent=pct+'% capacity';
}
function addSimLog(type){
  const log=document.getElementById('sim-log');
  const ts=new Date().toTimeString().slice(0,8);
  const occ=Math.max(0,entries-exits);
  const d=document.createElement('div'); d.className='ll';
  d.innerHTML=type==='entry'
    ? `<span class="lt">${ts}</span><span class="le">ENTRY  Door-A  occ→${occ}</span>`
    : `<span class="lt">${ts}</span><span class="lx">EXIT   Door-B  occ→${occ}</span>`;
  log.insertBefore(d,log.firstChild);
  if(log.children.length>40) log.removeChild(log.lastChild);
}
function flashNode(id){
  const el=document.getElementById(id);
  el.classList.remove('active-flash','fl');
  void el.offsetWidth;
  el.classList.add('active-flash','fl');
  setTimeout(()=>el.classList.remove('fl'),400);
}
function updateUserSensorView(){
  renderSim();
}

/* ======================== CLOCK ======================== */
function updateClock(id){
  const el=document.getElementById(id);
  if(!el) return;
  const tick=()=>{
    el.textContent='📅 '+new Date().toLocaleString('en-IN',{weekday:'long',year:'numeric',month:'long',day:'numeric',hour:'2-digit',minute:'2-digit',second:'2-digit'});
  };
  tick(); setInterval(tick,1000);
}

/* ======================== KEYBOARD ======================== */
document.addEventListener('keydown',e=>{
  if(e.key==='Enter'&&document.getElementById('login').classList.contains('active')) doLogin();
});
</script>
