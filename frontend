            <div class="sl">Door A — Entry</div>
          </div>
          <div class="flow-arrow">→</div>
          <div class="hub-node">
            <div class="ht">FLOWSYNC IQ DATA BUS</div>
            <div class="hv" id="hub-occ">0</div>
            <div class="hl">Live Occupancy</div>
          </div>
          <div class="flow-arrow">←</div>
          <div class="snode" id="dB">
            <div style="font-size:1.5rem">🚪</div>
            <div class="sv" id="dB-v">0</div>
            <div class="sl">Door B — Exit</div>
