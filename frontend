<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FlowSync IQ — Urban Facility Intelligence</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
:root {
  --primary: #6C3BFF;
  --primary-dark: #4A20D4;
  --primary-light: #EDE8FF;
  --accent: #FF6B35;
  --accent2: #00D2A0;
  --accent3: #FFD23F;
  --bg: #0B0C1A;
  --bg2: #12132A;
  --bg3: #1A1B35;
  --card: #1E1F3A;
  --card2: #252647;
  --border: rgba(108,59,255,0.2);
  --border2: rgba(0,255,180,0.12);
  --text: #F0F0FF;
  --text2: #A0A0C0;
  --text3: #6060A0;
  --red: #FF4D6D;
  --orange: #FF9F43;
  --green: #10D48A;
  --neon: #00ffb4;
  --blue: #4EAEFF;
  --yellow: #FFD23F;
  --radius: 16px;
  --radius-sm: 10px;
  --mono: 'JetBrains Mono', monospace;
}

*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden;}
h1,h2,h3,.logo{font-family:'Syne',sans-serif;}

/* BG ORBS */
.bg-orb{position:fixed;border-radius:50%;filter:blur(90px);opacity:0.1;pointer-events:none;z-index:0;animation:floatOrb 14s ease-in-out infinite;}
.orb1{width:700px;height:700px;background:var(--primary);top:-250px;left:-250px;animation-delay:0s;}
.orb2{width:500px;height:500px;background:var(--accent);top:40%;right:-150px;animation-delay:5s;}
.orb3{width:400px;height:400px;background:var(--accent2);bottom:5%;left:25%;animation-delay:10s;}
@keyframes floatOrb{0%,100%{transform:translate(0,0);}50%{transform:translate(40px,-40px);}}

/* NOISE TEXTURE */
body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");opacity:.4;pointer-events:none;z-index:0;}

.page{display:none;min-height:100vh;position:relative;z-index:1;}
.page.active{display:block;}

/* ======================== LANDING ======================== */
#landing{display:none;flex-direction:column;align-items:center;justify-content:center;text-align:center;min-height:100vh;padding:2rem;}
#landing.active{display:flex;}

.landing-badge{display:inline-flex;align-items:center;gap:8px;background:rgba(108,59,255,0.15);border:1px solid rgba(108,59,255,0.3);color:#BBA8FF;font-size:13px;font-weight:500;padding:6px 20px;border-radius:100px;margin-bottom:2rem;letter-spacing:0.05em;}
.landing-badge::before{content:'●';color:var(--neon);font-size:10px;animation:pulse 2s infinite;}
@keyframes pulse{0%,100%{opacity:1;}50%{opacity:0.2;}}

.landing h1{font-size:clamp(2.8rem,7vw,6rem);font-weight:800;line-height:1.05;letter-spacing:-0.03em;margin-bottom:1.5rem;}
.landing h1 .grad{background:linear-gradient(135deg,#6C3BFF,#FF6B35,#00D2A0,#00ffb4);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}

.landing-sub{font-size:1.15rem;color:var(--text2);max-width:640px;line-height:1.8;margin-bottom:3rem;font-weight:300;}

.feature-strip{display:flex;gap:1.5rem;flex-wrap:wrap;justify-content:center;margin-bottom:3rem;}
.feat-pill{display:flex;align-items:center;gap:8px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:100px;padding:8px 18px;font-size:0.82rem;color:var(--text2);}
.feat-pill span{font-size:1rem;}

.landing-cards{display:flex;gap:1.5rem;flex-wrap:wrap;justify-content:center;margin-bottom:4rem;}

.role-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:2rem 2.5rem;cursor:pointer;transition:all 0.35s cubic-bezier(0.34,1.56,0.64,1);width:280px;text-align:center;position:relative;overflow:hidden;}
.role-card::before{content:'';position:absolute;inset:0;opacity:0;transition:opacity 0.3s;border-radius:inherit;}
.admin-card::before{background:radial-gradient(circle at top,rgba(108,59,255,0.2),transparent);}
.user-card::before{background:radial-gradient(circle at top,rgba(0,210,160,0.2),transparent);}
.role-card:hover{transform:translateY(-10px) scale(1.02);border-color:rgba(108,59,255,0.5);box-shadow:0 20px 60px rgba(108,59,255,0.2);}
.role-card:hover::before{opacity:1;}

.role-icon{width:80px;height:80px;border-radius:24px;display:flex;align-items:center;justify-content:center;font-size:2.2rem;margin:0 auto 1.5rem;}
.admin-icon{background:rgba(108,59,255,0.2);border:1px solid rgba(108,59,255,0.3);}
.user-icon{background:rgba(0,210,160,0.2);border:1px solid rgba(0,210,160,0.3);}
.role-card h3{font-size:1.3rem;font-weight:700;margin-bottom:0.5rem;}
.role-card p{font-size:0.88rem;color:var(--text2);line-height:1.6;}
.role-btn{display:inline-block;margin-top:1.5rem;padding:10px 28px;border-radius:100px;font-size:0.85rem;font-weight:600;border:none;cursor:pointer;transition:all 0.2s;font-family:'Syne',sans-serif;}
.admin-card .role-btn{background:var(--primary);color:white;}
.user-card .role-btn{background:var(--accent2);color:#003d2d;}

.stats-strip{display:flex;gap:3rem;flex-wrap:wrap;justify-content:center;}
.stat-item{text-align:center;}
.stat-item .num{font-family:'Syne',sans-serif;font-size:2rem;font-weight:700;}
.stat-item .lbl{font-size:0.78rem;color:var(--text3);text-transform:uppercase;letter-spacing:0.08em;margin-top:4px;}

/* ======================== LOGIN ======================== */
#login{display:none;align-items:center;justify-content:center;min-height:100vh;padding:2rem;flex-direction:column;gap:2rem;}
#login.active{display:flex;}
.login-box{background:var(--card);border:1px solid var(--border);border-radius:24px;padding:2.5rem;width:100%;max-width:440px;position:relative;overflow:hidden;}
.login-box::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--primary),var(--accent),var(--accent2),var(--neon));}
.login-back{display:flex;align-items:center;gap:8px;color:var(--text2);font-size:0.9rem;cursor:pointer;background:none;border:none;margin-bottom:2rem;padding:0;transition:color 0.2s;}
.login-back:hover{color:var(--text);}
.login-box h2{font-size:1.8rem;font-weight:700;margin-bottom:0.4rem;}
.login-box .login-sub{color:var(--text2);font-size:0.9rem;margin-bottom:2rem;}
.form-group{margin-bottom:1.2rem;}
.form-group label{display:block;font-size:0.85rem;color:var(--text2);margin-bottom:6px;font-weight:500;}
.form-group input{width:100%;background:var(--bg3);border:1px solid rgba(255,255,255,0.08);border-radius:var(--radius-sm);padding:12px 16px;color:var(--text);font-family:'DM Sans',sans-serif;font-size:0.95rem;transition:border-color 0.2s,box-shadow 0.2s;outline:none;}
.form-group input:focus{border-color:var(--primary);box-shadow:0 0 0 3px rgba(108,59,255,0.15);}
.login-btn{width:100%;padding:14px;background:linear-gradient(135deg,var(--primary),var(--primary-dark));color:white;border:none;border-radius:var(--radius-sm);font-family:'Syne',sans-serif;font-size:1rem;font-weight:700;cursor:pointer;transition:all 0.2s;margin-top:0.5rem;}
.login-btn:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(108,59,255,0.4);}
.login-btn.green{background:linear-gradient(135deg,var(--accent2),#00a07a);}
.login-btn.green:hover{box-shadow:0 8px 24px rgba(0,210,160,0.4);}
.login-error{background:rgba(255,77,109,0.1);border:1px solid rgba(255,77,109,0.3);color:#ff8fa3;border-radius:var(--radius-sm);padding:10px 14px;font-size:0.85rem;margin-top:1rem;display:none;}
.demo-creds{background:rgba(108,59,255,0.08);border:1px solid rgba(108,59,255,0.2);border-radius:var(--radius-sm);padding:12px 16px;font-size:0.82rem;color:var(--text2);margin-top:1.2rem;}
.demo-creds strong{color:#BBA8FF;}

/* ======================== NAVBAR ======================== */
.navbar{display:flex;align-items:center;justify-content:space-between;padding:1rem 2rem;background:rgba(11,12,26,0.9);backdrop-filter:blur(24px);border-bottom:1px solid var(--border);position:sticky;top:0;z-index:100;}
.logo{font-size:1.4rem;font-weight:800;letter-spacing:-0.03em;}
.logo span{color:var(--primary);}
.logo em{color:var(--neon);font-style:normal;}
.nav-user{display:flex;align-items:center;gap:1rem;}
.nav-tabs{display:flex;gap:4px;background:rgba(255,255,255,0.05);border-radius:10px;padding:4px;}
.nav-tab{padding:7px 16px;border-radius:7px;font-size:0.82rem;font-weight:500;cursor:pointer;border:none;background:transparent;color:var(--text2);transition:all 0.2s;font-family:'DM Sans',sans-serif;}
.nav-tab.active{background:var(--card2);color:var(--text);}
.nav-badge{padding:4px 12px;border-radius:100px;font-size:0.78rem;font-weight:600;letter-spacing:0.05em;text-transform:uppercase;}
.nav-badge.admin{background:rgba(108,59,255,0.2);color:#BBA8FF;border:1px solid rgba(108,59,255,0.3);}
.nav-badge.user{background:rgba(0,210,160,0.2);color:#00D2A0;border:1px solid rgba(0,210,160,0.3);}
.nav-logout{background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);color:var(--text2);padding:6px 14px;border-radius:var(--radius-sm);font-size:0.85rem;cursor:pointer;transition:all 0.2s;font-family:'DM Sans',sans-serif;}
.nav-logout:hover{background:rgba(255,77,109,0.1);border-color:rgba(255,77,109,0.3);color:var(--red);}

/* ======================== DASHBOARD COMMON ======================== */
.dashboard{padding:2rem;max-width:1500px;margin:0 auto;}
.tab-section{display:none;}
.tab-section.active{display:block;}
.dash-header{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:2rem;flex-wrap:wrap;gap:1rem;}
.dash-title{font-size:2rem;font-weight:800;}
.dash-title span{color:var(--primary);}
.dash-sub{color:var(--text2);font-size:0.9rem;margin-top:4px;}

.facility-selector{margin-bottom:2rem;}
.facility-selector h3{font-size:0.78rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--text3);margin-bottom:1rem;font-family:var(--mono);}
.facility-grid{display:flex;flex-wrap:wrap;gap:8px;}
.fac-chip{display:flex;align-items:center;gap:8px;padding:8px 16px;background:var(--card);border:1px solid var(--border);border-radius:100px;cursor:pointer;transition:all 0.25s;font-size:0.85rem;color:var(--text2);white-space:nowrap;}
.fac-chip:hover{border-color:rgba(108,59,255,0.4);color:var(--text);}
.fac-chip.active{background:rgba(108,59,255,0.15);border-color:var(--primary);color:#BBA8FF;font-weight:500;}
.fac-chip .fac-icon{font-size:1rem;}

.location-select{margin-bottom:2rem;display:flex;align-items:center;gap:1rem;flex-wrap:wrap;}
.location-select label{font-size:0.85rem;color:var(--text2);font-weight:500;}
.location-select select{background:var(--card);border:1px solid var(--border);color:var(--text);border-radius:var(--radius-sm);padding:10px 16px;font-family:'DM Sans',sans-serif;font-size:0.9rem;outline:none;cursor:pointer;min-width:220px;transition:border-color 0.2s;}
.location-select select:focus{border-color:var(--primary);}

.overview-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(170px,1fr));gap:1rem;margin-bottom:2rem;}
.stat-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:1.5rem;position:relative;overflow:hidden;transition:transform 0.2s;}
.stat-card:hover{transform:translateY(-3px);}
.stat-card::after{content:'';position:absolute;bottom:0;left:0;right:0;height:3px;border-radius:0 0 var(--radius) var(--radius);}
.stat-card.c-purple::after{background:var(--primary);}
.stat-card.c-green::after{background:var(--green);}
.stat-card.c-orange::after{background:var(--orange);}
.stat-card.c-blue::after{background:var(--blue);}
.stat-card.c-red::after{background:var(--red);}
.stat-card.c-yellow::after{background:var(--yellow);}
.stat-card.c-neon::after{background:var(--neon);}
.stat-card .sc-icon{font-size:1.4rem;margin-bottom:0.8rem;display:block;}
.stat-card .sc-val{font-family:'Syne',sans-serif;font-size:2rem;font-weight:700;line-height:1;}
.stat-card .sc-lbl{font-size:0.78rem;color:var(--text2);margin-top:6px;}

.content-grid{display:grid;grid-template-columns:1fr 360px;gap:1.5rem;margin-bottom:2rem;}
.admin-panel{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:2rem;}
.panel-title{font-size:1.05rem;font-weight:700;margin-bottom:1.5rem;display:flex;align-items:center;gap:10px;font-family:'Syne',sans-serif;}
.panel-title-icon{width:32px;height:32px;border-radius:8px;background:rgba(108,59,255,0.2);display:flex;align-items:center;justify-content:center;font-size:1rem;}

.form-row{display:grid;grid-template-columns:1fr 1fr;gap:1rem;}
.input-group{margin-bottom:1.2rem;}
.input-group label{display:block;font-size:0.82rem;color:var(--text2);margin-bottom:6px;font-weight:500;}
.input-group input,.input-group select,.input-group textarea{width:100%;background:var(--bg3);border:1px solid rgba(255,255,255,0.07);border-radius:var(--radius-sm);padding:10px 14px;color:var(--text);font-family:'DM Sans',sans-serif;font-size:0.9rem;outline:none;transition:border-color 0.2s;}
.input-group input:focus,.input-group select:focus,.input-group textarea:focus{border-color:var(--primary);}
.input-group textarea{resize:vertical;min-height:80px;}

.range-group{margin-bottom:1.2rem;}
.range-group label{display:flex;justify-content:space-between;align-items:center;font-size:0.82rem;color:var(--text2);margin-bottom:8px;}
.range-group label span{font-weight:700;color:var(--text);font-size:1rem;}
.range-group input[type=range]{width:100%;accent-color:var(--primary);height:4px;border-radius:2px;cursor:pointer;}

.submit-btn{width:100%;padding:14px;background:linear-gradient(135deg,var(--primary),#8B5CF6);color:white;border:none;border-radius:var(--radius-sm);font-family:'Syne',sans-serif;font-size:1rem;font-weight:700;cursor:pointer;letter-spacing:0.03em;transition:all 0.25s;margin-top:0.5rem;}
.submit-btn:hover{transform:translateY(-2px);box-shadow:0 10px 30px rgba(108,59,255,0.4);}
.success-msg{background:rgba(16,212,138,0.1);border:1px solid rgba(16,212,138,0.3);color:var(--green);border-radius:var(--radius-sm);padding:12px;font-size:0.88rem;text-align:center;margin-top:1rem;display:none;}

.alerts-panel{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:1.5rem;display:flex;flex-direction:column;}
.alert-item{padding:1rem 0;border-bottom:1px solid rgba(255,255,255,0.05);display:flex;gap:12px;align-items:flex-start;}
.alert-item:last-child{border-bottom:none;padding-bottom:0;}
.alert-dot{width:8px;height:8px;border-radius:50%;margin-top:5px;flex-shrink:0;}
.alert-dot.high{background:var(--red);box-shadow:0 0 8px rgba(255,77,109,0.6);}
.alert-dot.med{background:var(--orange);box-shadow:0 0 8px rgba(255,159,67,0.6);}
.alert-dot.low{background:var(--green);box-shadow:0 0 8px rgba(16,212,138,0.6);}
.alert-content .al-title{font-size:0.88rem;font-weight:500;margin-bottom:3px;}
.alert-content .al-sub{font-size:0.78rem;color:var(--text2);}

.data-panel{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:2rem;overflow-x:auto;margin-bottom:2rem;}
.data-table{width:100%;border-collapse:collapse;font-size:0.85rem;}
.data-table th{text-align:left;padding:10px 14px;color:var(--text3);font-size:0.75rem;text-transform:uppercase;letter-spacing:0.08em;font-weight:600;border-bottom:1px solid rgba(255,255,255,0.06);white-space:nowrap;font-family:var(--mono);}
.data-table td{padding:12px 14px;border-bottom:1px solid rgba(255,255,255,0.04);color:var(--text);}
.data-table tr:hover td{background:rgba(108,59,255,0.04);}
.data-table tr:last-child td{border-bottom:none;}

.badge{display:inline-block;padding:3px 10px;border-radius:100px;font-size:0.72rem;font-weight:600;}
.badge-red{background:rgba(255,77,109,0.15);color:#FF8FA3;border:1px solid rgba(255,77,109,0.25);}
.badge-orange{background:rgba(255,159,67,0.15);color:#FFBB77;border:1px solid rgba(255,159,67,0.25);}
.badge-green{background:rgba(16,212,138,0.15);color:#40DCA0;border:1px solid rgba(16,212,138,0.25);}
.badge-blue{background:rgba(78,174,255,0.15);color:#80C8FF;border:1px solid rgba(78,174,255,0.25);}
.badge-neon{background:rgba(0,255,180,0.12);color:var(--neon);border:1px solid rgba(0,255,180,0.25);}

.flow-bar{height:6px;background:rgba(255,255,255,0.08);border-radius:3px;overflow:hidden;width:100px;display:inline-block;vertical-align:middle;}
.flow-fill{height:100%;border-radius:3px;transition:width 0.5s ease;}

.live-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:1rem;margin-bottom:2rem;}
.live-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:1.5rem;position:relative;overflow:hidden;transition:all 0.3s;}
.live-card:hover{border-color:rgba(108,59,255,0.4);transform:translateY(-2px);}
.live-card-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;}
.lc-title{font-weight:600;font-size:0.95rem;display:flex;align-items:center;gap:8px;}
.live-indicator{display:flex;align-items:center;gap:5px;font-size:0.72rem;color:var(--green);font-weight:500;font-family:var(--mono);}
.live-dot{width:6px;height:6px;background:var(--green);border-radius:50%;animation:pulse 1.5s infinite;}
.metric-row{display:flex;align-items:center;justify-content:space-between;padding:7px 0;border-bottom:1px solid rgba(255,255,255,0.04);font-size:0.85rem;}
.metric-row:last-child{border-bottom:none;}
.metric-row .m-key{color:var(--text2);}
.metric-row .m-val{font-weight:600;}
.capacity-ring{width:80px;height:80px;position:relative;margin:0 auto 1rem;}
.capacity-ring svg{width:80px;height:80px;transform:rotate(-90deg);}
.capacity-ring .ring-bg{fill:none;stroke:rgba(255,255,255,0.07);stroke-width:6;}
.capacity-ring .ring-fill{fill:none;stroke-width:6;stroke-linecap:round;transition:stroke-dasharray 0.8s ease;}
.ring-label{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-size:1.1rem;font-weight:700;}

.empty-state{text-align:center;padding:4rem 2rem;color:var(--text2);}
.empty-state .es-icon{font-size:3rem;margin-bottom:1rem;opacity:0.5;}
.empty-state h3{font-size:1.1rem;margin-bottom:0.5rem;color:var(--text);}
.empty-state p{font-size:0.88rem;max-width:300px;margin:0 auto;}

.last-updated{font-size:0.75rem;color:var(--text3);margin-top:1rem;text-align:right;font-family:var(--mono);}

/* ======================== HARDWARE TAB ======================== */
.hw-banner{display:flex;gap:12px;background:rgba(245,158,11,0.06);border:1px solid rgba(245,158,11,0.22);border-left:3px solid #f59e0b;border-radius:10px;padding:14px 18px;margin-bottom:2rem;font-size:0.84rem;color:rgba(245,158,11,0.9);line-height:1.7;}
.hw-banner strong{color:#f59e0b;}

.hw-stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;margin-bottom:2rem;}
.hw-stat{background:var(--card);border:1px solid var(--border2);border-radius:12px;padding:1.3rem;position:relative;overflow:hidden;transition:border-color 0.2s,transform 0.2s;}
.hw-stat:hover{border-color:rgba(0,255,180,0.28);transform:translateY(-2px);}
.hw-stat::before{content:'';position:absolute;top:0;left:0;width:3px;height:100%;}
.hw-stat:nth-child(1)::before{background:var(--neon);}
.hw-stat:nth-child(2)::before{background:var(--blue);}
.hw-stat:nth-child(3)::before{background:#f59e0b;}
.hw-stat:nth-child(4)::before{background:#2dd4bf;}
.hw-stat .hw-icon{font-size:1.4rem;margin-bottom:0.6rem;}
.hw-stat h4{font-size:0.82rem;font-weight:600;margin-bottom:3px;}
.hw-stat p{font-size:0.72rem;color:var(--text2);line-height:1.6;margin-bottom:8px;}
.hw-stat .hw-val{font-family:var(--mono);font-size:1.5rem;font-weight:700;}
.hw-stat:nth-child(1) .hw-val{color:var(--neon);}
.hw-stat:nth-child(2) .hw-val{color:var(--blue);}
.hw-stat:nth-child(3) .hw-val{color:#f59e0b;}
.hw-stat:nth-child(4) .hw-val{color:#2dd4bf;}
.hw-stat .hw-lbl{font-size:0.68rem;color:var(--text3);font-family:var(--mono);}

/* Sim panel */
.sim-panel{background:rgba(13,17,23,0.8);border:1px solid var(--border2);border-radius:var(--radius);padding:1.8rem;margin-bottom:2rem;}
.sim-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem;flex-wrap:wrap;gap:10px;}
.sim-top h2{font-size:1rem;font-weight:600;}
.sim-live-badge{display:inline-flex;align-items:center;gap:6px;font-family:var(--mono);font-size:10px;letter-spacing:2px;color:var(--neon);background:rgba(0,255,180,0.09);border:1px solid rgba(0,255,180,0.22);padding:4px 10px;border-radius:4px;}

.sensor-flow{display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:1.5rem;}
.snode{background:rgba(19,25,32,0.9);border:1px solid var(--border2);border-radius:10px;padding:1rem 1.2rem;text-align:center;min-width:100px;flex-shrink:0;transition:all 0.3s;}
.snode.active-flash{border-color:rgba(0,255,180,0.4);box-shadow:0 0 16px rgba(0,255,180,0.15);}
.snode .sv{font-family:var(--mono);font-size:1.4rem;font-weight:700;color:var(--neon);}
.snode .sl{font-size:0.66rem;color:var(--text3);margin-top:3px;}
.flow-arrow{color:var(--neon);font-size:1.2rem;opacity:0.4;animation:arrowPulse 1.5s ease-in-out infinite;flex-shrink:0;}
@keyframes arrowPulse{0%,100%{opacity:0.15;}50%{opacity:0.8;}}
.hub-node{flex:1;min-width:150px;background:rgba(0,255,180,0.04);border:1px dashed rgba(0,255,180,0.25);border-radius:12px;padding:1.2rem;text-align:center;}
.hub-node .ht{font-size:0.65rem;color:var(--text3);font-family:var(--mono);margin-bottom:4px;letter-spacing:1px;}
.hub-node .hv{font-family:var(--mono);font-size:2rem;font-weight:700;color:var(--neon);}
.hub-node .hl{font-size:0.65rem;color:var(--text3);}

.sim-log{background:rgba(19,25,32,0.9);border:1px solid var(--border2);border-radius:8px;padding:1rem;height:120px;overflow-y:auto;font-family:var(--mono);font-size:0.72rem;color:var(--text2);margin-bottom:1.2rem;}
.sim-log::-webkit-scrollbar{width:2px;}
.sim-log::-webkit-scrollbar-thumb{background:rgba(0,255,180,0.2);}
.ll{padding:2px 0;display:flex;gap:12px;}
.lt{color:rgba(0,255,180,0.45);flex-shrink:0;}
.le{color:var(--neon);}
.lx{color:var(--blue);}

.sim-controls{display:flex;align-items:center;gap:10px;flex-wrap:wrap;}
.sim-btn{display:inline-flex;align-items:center;gap:7px;background:rgba(0,255,180,0.09);border:1px solid rgba(0,255,180,0.28);color:var(--neon);font-family:var(--mono);font-size:0.78rem;padding:9px 18px;border-radius:6px;cursor:pointer;transition:all 0.2s;}
.sim-btn:hover{background:rgba(0,255,180,0.16);}
.sim-btn.stop{background:rgba(242,92,92,0.09);border-color:rgba(242,92,92,0.28);color:var(--red);}
.sim-btn.rst{border-color:rgba(255,255,255,0.08);color:var(--text2);background:transparent;}
.spd-ctrl{display:flex;align-items:center;gap:8px;font-family:var(--mono);font-size:0.74rem;color:var(--text2);}
.spd-ctrl input{accent-color:var(--neon);width:70px;}

/* Occupancy */
.occ-panel{background:var(--card);border:1px solid var(--border2);border-radius:var(--radius);padding:1.5rem;margin-bottom:2rem;}
.occ-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:1.2rem;}
.occ-header h2{font-size:1rem;font-weight:600;}
.occ-big{font-family:var(--mono);font-size:2.2rem;font-weight:700;}
.occ-track{height:14px;background:rgba(255,255,255,0.06);border-radius:100px;overflow:hidden;margin-bottom:6px;}
.occ-fill{height:100%;border-radius:100px;transition:width 0.8s ease,background 0.4s;}
.occ-labels{display:flex;justify-content:space-between;font-size:0.68rem;color:var(--text3);margin-bottom:1.2rem;font-family:var(--mono);}
.occ-mini{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;}
.occ-ms{background:rgba(19,25,32,0.8);border-radius:8px;padding:10px;text-align:center;}
.occ-ms .mv{font-family:var(--mono);font-size:1.1rem;font-weight:700;}
.occ-ms .ml{font-size:0.65rem;color:var(--text3);margin-top:2px;}

/* Pipeline */
.pipeline-panel{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:1.5rem;margin-bottom:2rem;overflow-x:auto;}
.pipeline-panel h2{font-size:1rem;font-weight:600;margin-bottom:1.2rem;}
.pipeline{display:flex;align-items:center;min-width:500px;}
.pn{background:rgba(19,25,32,0.8);border:1px solid rgba(0,255,180,0.15);border-radius:10px;padding:0.9rem 1rem;text-align:center;flex-shrink:0;}
.pn .pi{font-size:1.3rem;margin-bottom:4px;}
.pn .pt{font-size:0.75rem;font-weight:600;}
.pn .ps{font-size:0.62rem;color:var(--text3);}
.pa{flex:1;display:flex;flex-direction:column;align-items:center;gap:2px;padding:0 4px;}
.pa .pl{height:2px;width:100%;background:linear-gradient(90deg,var(--neon),rgba(0,255,180,0.1));}
.pa .pk{font-size:0.58rem;color:var(--neon);font-family:var(--mono);}

/* Scrollbar */
::-webkit-scrollbar{width:6px;height:6px;}
::-webkit-scrollbar-track{background:transparent;}
::-webkit-scrollbar-thumb{background:rgba(108,59,255,0.3);border-radius:3px;}

@keyframes fadeUp{from{opacity:0;transform:translateY(20px);}to{opacity:1;transform:translateY(0);}}
.fade-in{animation:fadeUp 0.4s ease forwards;}
@keyframes flash{0%,100%{box-shadow:none;}50%{box-shadow:0 0 16px rgba(0,255,180,0.3);border-color:rgba(0,255,180,0.5);}}
.fl{animation:flash 0.4s ease;}

@media(max-width:900px){
  .content-grid{grid-template-columns:1fr;}
  .form-row{grid-template-columns:1fr;}
  .sensor-flow{flex-direction:column;align-items:stretch;}
  .flow-arrow{text-align:center;}
}
</style>
</head>
<body>

<div class="bg-orb orb1"></div>
<div class="bg-orb orb2"></div>
<div class="bg-orb orb3"></div>

<!-- ==================== LANDING ==================== -->
<div id="landing" class="page active landing">
