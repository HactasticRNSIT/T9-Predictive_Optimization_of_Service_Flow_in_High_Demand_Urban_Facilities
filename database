async function seed() {
  console.log('🌱 Connecting to MongoDB...');
  await mongoose.connect(MONGO_URI);
  console.log('✅ Connected');

  // Clear existing
  await User.deleteMany({});
  await FacilityMetrics.deleteMany({});
  console.log('🗑️  Cleared existing data');

  // Insert users
  const createdUsers = await User.create(SEED_USERS);
  console.log(`👤 Created ${createdUsers.length} users:`);
  createdUsers.forEach(u => console.log(`   - ${u.role}: ${u.email}`));

  // Insert metrics (link to admin users)
  const userMap = {};
  createdUsers.forEach(u => { userMap[u.email] = u; });

  const metricsToInsert = SEED_METRICS.map(item => {
    const admin = userMap[item.adminEmail];
    return {
      facilityType: item.facilityType,
      locationId: item.locationId,
      locationName: item.locationName,
      admin: admin._id,
      adminName: admin.name,
      metrics: item.metrics,
    };
  });

  const createdMetrics = await FacilityMetrics.insertMany(metricsToInsert);
  console.log(`📊 Created ${createdMetrics.length} facility metric records`);

  console.log('\n✅ Seed complete!');
  console.log('\n🔑 Demo Credentials:');
  console.log('   Admin:         admin@urbanflow.com / admin123');
  console.log('   Airport Admin: airportadmin@urbanflow.com / admin123');
  console.log('   User:          user@urbanflow.com / user123');

  await mongoose.disconnect();
  process.exit(0);
}

seed().catch(err => {
  console.error('❌ Seed failed:', err);
  process.exit(1);
});
